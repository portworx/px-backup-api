            }
          }
        ],
        "tags": [
          "ContainerOrchestrator"
        ]
      }
    },
    "/v1/containerorchestrator/kvget": {
      "post": {
        "summary": "Get certificate data from Kubernetes Secret",
        "operationId": "ContainerOrchestrator_KVGet",
